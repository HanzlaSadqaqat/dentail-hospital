# MongoDB Atlas connection string
MONGODB_URI=

# Secret used to sign admin session JWTs (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Vercel Blob read/write token (from the Vercel dashboard > Storage > Blob)
BLOB_READ_WRITE_TOKEN=

# Used once by `npm run seed` to bootstrap the first admin account
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
